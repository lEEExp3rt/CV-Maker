{
  "name": "CV-Maker",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Dev Server",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.associations": {
          "*.yaml": "yaml",
          "*.yml": "yaml"
        }
      }
    }
  },
  "postCreateCommand": "npm install",
  "remoteUser": "node"
}
