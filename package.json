{
  "name": "cv-maker",
  "private": true,
  "version": "1.0.0",
  "description": "A clean, professional CV/Resume maker for Chinese university students applying for tech internships and campus recruitment",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "export": "npm run build && node scripts/export-pdf.mjs",
    "clean": "rm -rf dist .vite node_modules"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.0",
    "puppeteer": "^24.15.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0"
  }
}
